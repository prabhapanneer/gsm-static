# Copy to .env and fill in (never commit .env)
#
# Local: from the repo root run `npm run dev` — Vite includes POST /contact (see
# ../scripts/vite-plugin-gsm-contact.mjs). You only need a separate `cd contact-server && npm start`
# if you want the gateway on its own port (e.g. 9006).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_TO=recipient@example.com
# HTML email: absolute URL to site logo (same file as index.html header, e.g. img-39d783410317.jpg)
# MAIL_LOGO_URL=http://localhost/GSM/assets/images/img-39d783410317.jpg
# MAIL_SITE_URL=https://gsminvestservices.com
# MAIL_SITE_LABEL=GSM Investment Services
# Optional
# MAIL_BCC=
# FORMS_SKIP_EMAIL=0
# CONTACT_PORT=9006
# On Render/Railway etc., the platform sets PORT — leave CONTACT_PORT unset so that is used.
# React site (Vite): set the same URL in the web app as VITE_CONTACT_API (see project root .env.example).
#
# After submit, browser redirects here for non-JSON form posts (JSON fetch from the React app does not redirect)
CONTACT_SUCCESS_REDIRECT=http://localhost/GSM/index.html?contact=sent#contact
CONTACT_ERROR_REDIRECT=http://localhost/GSM/index.html?contact=error#contact
# Production examples:
# CONTACT_SUCCESS_REDIRECT=https://www.gsminvestservices.com/index.html?contact=sent#contact
# CONTACT_ERROR_REDIRECT=https://www.gsminvestservices.com/index.html?contact=error#contact
